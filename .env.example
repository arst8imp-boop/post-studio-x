# Post Studio X 用 .env のテンプレート。
# このファイルをコピーして .env として保存し、値を自分で埋めてください。
#
#   cp .env.example .env

# --- データベース（履歴・アカウント・使用量の保存に必須） ------------------
# Neon（無料のクラウド Postgres）の接続 URL。
# Neon ダッシュボード → Connection string の URL をそのまま貼る。
# ※ 基本の生成だけなら未設定でも起動できますが、履歴・アカウント・バズは使えません。
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# --- API課金の予算（安全のため既定は 0＝ブロック） -------------------------
# 0 のあいだは、サブスク上限時も API 課金せず生成を止めます（画面のトグルで一時解除可）。
API_MONTHLY_BUDGET_JPY=0

# --- 生成系（任意） --------------------------------------------------------
# Anthropic API キー（サブスク上限時のフォールバック用。無くてもサブスク認証で動く）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Gemini API キー（X記事のカバー画像を使うときだけ必要）
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Gemini 画像モデル（任意・既定 gemini-3-pro-image-preview）
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# --- X API（任意：バズ自動収集を使う場合のみ） -----------------------------
# BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAA...

# --- 任意設定 --------------------------------------------------------------
# サーバ起動ポート（既定 7879）
# POST_STUDIO_PORT=7879
